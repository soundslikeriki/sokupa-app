# Google AI Studio / Vertex で発行した API キー
GEMINI_API_KEY=
# @ai-sdk/google（/api/order-from-ocr）用。未設定なら GEMINI_API_KEY にフォールバック
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase（Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用。クライアントに絶対に載せないこと
SUPABASE_SERVICE_ROLE_KEY=

# 管理画面アクセス制御（LINEユーザーID）
ADMIN_LINE_USER_ID=
